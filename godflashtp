local function createKeybindButton(parent, text, yPos, configType)
	local btn = Instance.new("TextButton", parent)
	btn.Size = UDim2.new(0.9, 0, 0, 28)
	btn.Position = UDim2.new(0.05, 0, 0, yPos)
	btn.BackgroundColor3 = Color3.fromRGB(30, 30, 36)
	btn.Text = text .. ": " .. string.sub(tostring(keybindConfigs[configType].key), 10)
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.TextSize = 11
	btn.Font = Enum.Font.GothamMedium
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
	
	btn.MouseButton1Click:Connect(function()
		local oldText = btn.Text
		btn.Text = "PRESS ANY KEY..."
		btn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
		
		local connection
		connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
			if gameProcessed then return end
			if input.KeyCode ~= Enum.KeyCode.Unknown then
				keybindConfigs[configType].key = input.KeyCode
				
				if configType == "semiF" then
					ContextActionService:BindAction("SemiF", function(actionName, inputState, inputObj)
						if inputState == Enum.UserInputState.Begin then
							executeSemiF()
						end
					end, false, input.KeyCode)
				elseif configType == "semiG" then
					ContextActionService:BindAction("SemiG", function(actionName, inputState, inputObj)
						if inputState == Enum.UserInputState.Begin then
							executeSemiG()
						end
					end, false, input.KeyCode)
				elseif configType == "full" then
					ContextActionService:BindAction("Full", function(actionName, inputState, inputObj)
						if inputState == Enum.UserInputState.Begin then
							executeFull()
						end
					end, false, input.KeyCode)
				end
				
				btn.Text = text .. ": " .. string.sub(tostring(input.KeyCode), 10)
				btn.BackgroundColor3 = Color3.fromRGB(30, 30, 36)
				connection:Disconnect()
			end
		end)
		
		task.delay(5, function()
			if connection and connection.Connected then
				connection:Disconnect()
				btn.Text = oldText
				btn.BackgroundColor3 = Color3.fromRGB(30, 30, 36)
			end
		end)
	end)
	
	return btn
end

