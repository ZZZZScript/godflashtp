-- // [5] FUNÇÕES //
local function updateSlider(value)
    triggerPercent = math.clamp(value, 0, 1)
    SliderFill.Size = UDim2.new(triggerPercent, 0, 1, 0)
    SliderKnob.Position = UDim2.new(triggerPercent, -8, 0.5, -8)
    PercentLabel.Text = math.floor(triggerPercent * 100) .. "%"
end

-- Detecta tipo de entrada (mouse ou toque)
local function getInputType(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        return "Mouse"
    elseif input.UserInputType == Enum.UserInputType.Touch then
        return "Touch"
    end
    return nil
end

-- Arrastar GUI (funciona com mouse e toque)
TitleBar.InputBegan:Connect(function(input)
    local inputType = getInputType(input)
    if inputType == "Mouse" or inputType == "Touch" then
        draggingGui = true
        dragStartPos = input.Position
        guiStartPos = MainFrame.Position
    end
end)

TitleBar.InputEnded:Connect(function(input)
    local inputType = getInputType(input)
    if inputType == "Mouse" or inputType == "Touch" then
        draggingGui = false
    end
end)

-- Arrastar Slider
local function getSliderValue(input)
    local relativeX = (input.Position.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X
    return math.clamp(relativeX, 0, 1)
end

SliderBar.InputBegan:Connect(function(input)
    local inputType = getInputType(input)
    if inputType == "Mouse" or inputType == "Touch" then
        draggingSlider = true
        updateSlider(getSliderValue(input))
    end
end)

SliderKnob.InputBegan:Connect(function(input)
    local inputType = getInputType(input)
    if inputType == "Mouse" or inputType == "Touch" then
        draggingSlider = true
