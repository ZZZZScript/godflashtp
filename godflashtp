-- ── TELEPORT FUNCTION (LUMINA HUB STYLE) ──
local function TeleportTo(position)
    local char = LocalPlayer.Character
    if not char then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    hrp.CFrame = CFrame.new(position)
    task.wait(0.1)
    hrp.Position = position
    task.wait(0.05)
    hrp.CFrame = CFrame.new(position)
    
    return true
end

-- ── BLOCK OTHER PLAYERS ──
local function blockOtherPlayers()
    if not blockEnabled then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            pcall(function() 
                StarterGui:SetCore("PromptBlockPlayer", plr)
            end)
            task.wait(0.05)
        end
    end
end

-- ── FIND TOOL ──
local function findTool(namePart)
    for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if item:IsA("Tool") and item.Name:lower():find(namePart:lower()) then return item end
    end
    if LocalPlayer.Character then
        for _, item in ipairs(LocalPlayer.Character:GetChildren()) do
            if item:IsA("Tool") and item.Name:lower():find(namePart:lower()) then return item end
        end
    end
    return nil
end

-- ── USE QUANTUM CLONER ──
local function UseQuantumCloner()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    local clone = findTool("Quantum cloner") or findTool("quantum cloner") or findTool("Quantum")
    
    if clone and hum then
        hum:EquipTool(clone)
        task.wait(0.2)
        pcall(function() clone:Activate() end)
        return true
    end
    return false
end

